<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nossas Metas & Conquistas 🎯</title>
    <style>
        :root {
            --card-bg: rgba(255, 255, 255, 0.85);
            --text-color: #2d3748;
            --accent-color: #2c7a7b;
            --accent-light: rgba(230, 255, 250, 0.9);
            --border-color: rgba(226, 232, 240, 0.8);
            --success-color: #38a169;
            --warning-color: #dd6b20;
            --danger-color: #e53e3e;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --card-bg: rgba(45, 55, 72, 0.85);
                --text-color: #edf2f7;
                --border-color: rgba(74, 85, 104, 0.8);
                --accent-light: rgba(35, 78, 82, 0.9);
            }
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            /* Puxa a imagem MJ.png que você colocou no repositório */
            background-image: url('MJ.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            color: var(--text-color);
            padding: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.15);
            z-index: -1;
        }

        .container {
            width: 100%;
            max-width: 600px;
            background: var(--card-bg);
            padding: 20px;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        header {
            text-align: center;
            margin-bottom: 20px;
        }

        header h1 {
            font-size: 24px;
            color: var(--accent-color);
            margin-bottom: 5px;
        }

        @media (prefers-color-scheme: dark) {
            header h1 { color: #81e6d9; }
        }

        header p {
            font-size: 13px;
            opacity: 0.9;
            font-weight: 500;
        }

        .dashboard {
            background: var(--accent-light);
            border-radius: 14px;
            padding: 15px;
            margin-bottom: 20px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            text-align: center;
            border: 1px solid rgba(44, 122, 123, 0.3);
        }

        .dash-card h4 {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            opacity: 0.8;
            margin-bottom: 4px;
        }

        .dash-card p {
            font-size: 14px;
            font-weight: 700;
            color: var(--accent-color);
        }

        @media (prefers-color-scheme: dark) {
            .dash-card p { color: #81e6d9; }
        }

        .add-form {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
        }

        .add-form input {
            flex-grow: 1;
            padding: 12px;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.9);
            color: #2d3748;
            font-size: 14px;
        }

        @media (prefers-color-scheme: dark) {
            .add-form input { background: rgba(30, 41, 59, 0.9); color: #edf2f7; }
        }

        .add-form button {
            background: var(--accent-color);
            color: white;
            border: none;
            padding: 0 16px;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
        }

        #lista-vazia {
            text-align: center;
            padding: 30px;
            opacity: 0.8;
            font-size: 14px;
            font-weight: 500;
        }

        .meta-item {
            background: rgba(255, 255, 255, 0.7);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            padding: 15px;
            margin-bottom: 12px;
        }

        @media (prefers-color-scheme: dark) {
            .meta-item { background: rgba(45, 55, 72, 0.6); }
        }

        .item-main {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .item-left {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-grow: 1;
        }

        .item-left input[type="checkbox"] {
            width: 22px;
            height: 22px;
            accent-color: var(--success-color);
            cursor: pointer;
        }

        .item-title {
            font-size: 15px;
            font-weight: 600;
        }

        .item-actions {
            display: flex;
            gap: 4px;
        }

        .action-btn {
            background: rgba(255,255,255,0.5);
            border: 1px solid var(--border-color);
            cursor: pointer;
            font-size: 14px;
            padding: 6px 10px;
            border-radius: 8px;
        }

        .item-finances {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            margin-top: 8px;
        }

        @media (max-width: 480px) {
            .item-finances {
                grid-template-columns: 1fr;
                gap: 6px;
            }
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .input-group label {
            font-size: 11px;
            opacity: 0.8;
            font-weight: 700;
        }

        .input-group input {
            padding: 8px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background: rgba(255,255,255,0.9);
            color: #2d3748;
            font-size: 13px;
            width: 100%;
        }

        .result-box {
            padding: 8px;
            background: rgba(0,0,0,0.04);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
            min-height: 33px;
            display: flex;
            align-items: center;
        }

        .missing-value { color: var(--warning-color); }
        .completed-value { color: var(--success-color); }

        .progress-bar-container {
            width: 100%;
            height: 6px;
            background: rgba(0,0,0,0.1);
            border-radius: 3px;
            margin-top: 12px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            width: 0%;
            background: var(--success-color);
            transition: width 0.3s ease;
        }

        .meta-item.item-done {
            border-color: var(--success-color);
            background: rgba(240, 253, 244, 0.85);
        }

        footer {
            margin-top: 20px;
            text-align: center;
            font-size: 12px;
            opacity: 0.9;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>Nossas Metas & Conquistas 🏢🚗</h1>
        <p>Planejamento livre e financeiro a dois</p>
    </header>

    <div class="dashboard">
        <div class="dash-card"><h4>Total</h4><p id="total-geral">R$ 0,00</p></div>
        <div class="dash-card"><h4>Guardado</h4><p id="total-guardado">R$ 0,00</p></div>
        <div class="dash-card"><h4>Falta</h4><p id="total-falta" style="color: var(--warning-color);">R$ 0,00</p></div>
    </div>

    <div class="add-form">
        <input type="text" id="novo-item-nome" placeholder="O que vamos planejar? Ex: Viagem, Moto...">
        <button id="btn-adicionar">Adicionar</button>
    </div>

    <div id="lista-container">
        <div id="lista-vazia">Nenhum plano adicionado ainda. Comece digitando acima! 🚀</div>
    </div>

    <footer>
        <p>Construindo nosso futuro juntos. 🥂</p>
    </footer>
</div>

<script>
    const SENHA_CORRETA = '1234'; 
    let metas = [];

    const carregarDadosSalvos = () => {
        const dados = localStorage.getItem('minhas_metas_casal_foto');
        if (dados) metas = JSON.parse(dados);
    };

    const salvarDados = () => {
        localStorage.setItem('minhas_metas_casal_foto', JSON.stringify(metas));
    };

    const formatMoeda = (valor) => {
        return valor.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    };

    const renderizarLista = () => {
        const container = document.getElementById('lista-container');
        const vaziaDiv = document.getElementById('lista-vazia');
        
        container.querySelectorAll('.meta-item').forEach(el => el.remove());

        if (metas.length === 0) {
            vaziaDiv.style.display = 'block';
        } else {
            vaziaDiv.style.display = 'none';
        }

        let globalTotal = 0;
        let globalGuardado = 0;
        let globalFalta = 0;

        metas.forEach((meta, index) => {
            const total = parseFloat(meta.total) || 0;
            const guardado = parseFloat(meta.guardado) || 0;
            let falta = total - guardado;
            if (falta < 0) falta = 0;

            globalTotal += total;
            globalGuardado += guardado;
            globalFalta += falta;

            const pPct = total > 0 ? Math.min((guardado / total) * 100, 100) : 0;

            const itemDiv = document.createElement('div');
            itemDiv.className = `meta-item ${meta.checked ? 'item-done' : ''}`;
            
            itemDiv.innerHTML = `
                <div class="item-main">
                    <div class="item-left">
                        <input type="checkbox" class="done-check" ${meta.checked ? 'checked' : ''}>
                        <span class="item-title">${meta.nome}</span>
                    </div>
                    <div class="item-actions">
                        <button class="action-btn btn-search">🔍</button>
                        <button class="action-btn btn-delete" style="color: var(--danger-color);">🗑️</button>
                    </div>
                </div>
                <div class="item-finances">
                    <div class="input-group"><label>Valor Total</label><input type="number" class="val-total" value="${meta.total}" step="0.01"></div>
                    <div class="input-group"><label>Já Guardado</label><input type="number" class="val-guardado" value="${meta.guardado}" step="0.01"></div>
                    <div class="input-group"><label>Falta</label><div class="result-box ${falta === 0 && total > 0 ? 'completed-value' : 'missing-value'}">${falta === 0 && total > 0 ? 'Concluído!' : formatMoeda(falta)}</div></div>
                </div>
                <div class="progress-bar-container"><div class="progress-bar" style="width: ${pPct}%"></div></div>
            `;

            itemDiv.querySelector('.done-check').addEventListener('change', (e) => {
                metas[index].checked = e.target.checked;
                salvarDados();
                renderizarLista();
            });

            itemDiv.querySelector('.val-total').addEventListener('input', (e) => {
                metas[index].total = e.target.value;
                salvarDados();
                atualizarApenasTotais();
            });

            itemDiv.querySelector('.val-guardado').addEventListener('input', (e) => {
                metas[index].guardado = e.target.value;
                salvarDados();
                atualizarApenasTotais();
            });

            itemDiv.querySelector('.btn-search').addEventListener('click', () => {
                window.open(`https://www.google.com/search?tbm=shop&q=${encodeURIComponent(meta.nome)}`, '_blank');
            });

            itemDiv.querySelector('.btn-delete').addEventListener('click', () => {
                const senhaDigitada = prompt('Digite a senha para confirmar a exclusão:');
                if (senhaDigitada === SENHA_CORRETA) {
                    metas.splice(index, 1);
                    salvarDados();
                    renderizarLista();
                } else if (senhaDigitada !== null) {
                    alert('Senha incorreta!');
                }
            });

            container.appendChild(itemDiv);
        });

        document.getElementById('total-geral').textContent = formatMoeda(globalTotal);
        document.getElementById('total-guardado').textContent = formatMoeda(globalGuardado);
        document.getElementById('total-falta').textContent = formatMoeda(globalFalta);
    };

    const atualizarApenasTotais = () => {
        let globalTotal = 0; let globalGuardado = 0; let globalFalta = 0;
        document.querySelectorAll('.meta-item').forEach((item) => {
            const total = parseFloat(item.querySelector('.val-total').value) || 0;
            const guardado = parseFloat(item.querySelector('.val-guardado').value) || 0;
            let falta = total - guardado; if (falta < 0) falta = 0;
            globalTotal += total; globalGuardado += guardado; globalFalta += falta;
            item.querySelector('.result-box').textContent = (falta === 0 && total > 0) ? "Concluído!" : formatMoeda(falta);
            item.querySelector('.progress-bar').style.width = `${total > 0 ? Math.min((guardado / total) * 100, 100) : 0}%`;
        });
        document.getElementById('total-geral').textContent = formatMoeda(globalTotal);
        document.getElementById('total-guardado').textContent = formatMoeda(globalGuardado);
        document.getElementById('total-falta').textContent = formatMoeda(globalFalta);
    };

    const adicionarNovoItem = () => {
        const input = document.getElementById('novo-item-nome');
        if (input.value.trim() === '') return;
        metas.push({ nome: input.value.trim(), checked: false, total: '', guardado: '' });
        input.value = ''; salvarDados(); renderizarLista();
    };

    document.getElementById('btn-adicionar').addEventListener('click', adicionarNovoItem);
    document.getElementById('novo-item-nome').addEventListener('keypress', (e) => { if (e.key === 'Enter') adicionarNovoItem(); });

    carregarDadosSalvos();
    renderizarLista();
</script>
</body>
</html>
