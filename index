<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nossas Metas & Conquistas 🎯</title>
    <style>
        :root {
            --bg-color: #f4f7f9;
            --card-bg: #ffffff;
            --text-color: #2d3748;
            --primary-color: #4a5568;
            --accent-color: #2c7a7b;
            --accent-light: #e6fffa;
            --border-color: #e2e8f0;
            --success-color: #38a169;
            --warning-color: #dd6b20;
            --danger-color: #e53e3e;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg-color: #1a202c;
                --card-bg: #2d3748;
                --text-color: #edf2f7;
                --border-color: #4a5568;
                --accent-light: #234e52;
            }
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 650px;
            background: var(--card-bg);
            padding: 25px;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        }

        header {
            text-align: center;
            margin-bottom: 25px;
        }

        header h1 {
            font-size: 24px;
            color: var(--accent-color);
            margin-bottom: 5px;
        }

        /* Painel de Valores Gerais */
        .dashboard {
            background: var(--accent-light);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 25px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            text-align: center;
            border: 1px solid var(--accent-color);
        }

        .dash-card h4 {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            opacity: 0.8;
            margin-bottom: 5px;
        }

        .dash-card p {
            font-size: 15px;
            font-weight: 700;
            color: var(--accent-color);
        }

        @media (prefers-color-scheme: dark) {
            .dash-card p { color: #81e6d9; }
        }

        /* Formulário de Cadastro */
        .add-form {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
        }

        .add-form input {
            flex-grow: 1;
            padding: 12px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background: var(--card-bg);
            color: var(--text-color);
            font-size: 15px;
        }

        .add-form button {
            background: var(--accent-color);
            color: white;
            border: none;
            padding: 0 20px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .add-form button:hover {
            opacity: 0.9;
        }

        /* Container da Lista Vazia */
        #lista-vazia {
            text-align: center;
            padding: 30px;
            opacity: 0.5;
            font-size: 15px;
        }

        /* Item Gerado Dinamicamente */
        .meta-item {
            background: rgba(0,0,0,0.01);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 12px;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (prefers-color-scheme: dark) {
            .meta-item { background: rgba(255,255,255,0.02); }
        }

        .item-main {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .item-left {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-grow: 1;
        }

        .item-left input[type="checkbox"] {
            width: 20px;
            height: 20px;
            accent-color: var(--success-color);
            cursor: pointer;
        }

        .item-title {
            font-size: 15px;
            font-weight: 600;
        }

        .item-actions {
            display: flex;
            gap: 5px;
        }

        .action-btn {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 16px;
            padding: 4px 8px;
            border-radius: 6px;
            transition: background 0.2s;
        }
        .action-btn:hover {
            background: var(--border-color);
        }
        .btn-delete:hover {
            background: rgba(229, 62, 62, 0.1);
        }

        /* Inputs Financeiros */
        .item-finances {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 8px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .input-group label {
            font-size: 11px;
            opacity: 0.7;
            font-weight: 600;
        }

        .input-group input {
            padding: 6px 8px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            background: var(--card-bg);
            color: var(--text-color);
            font-size: 13px;
            width: 100%;
        }

        .result-box {
            padding: 6px 8px;
            background: rgba(0,0,0,0.03);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
        }

        @media (prefers-color-scheme: dark) {
            .result-box { background: rgba(255,255,255,0.05); }
        }

        .missing-value { color: var(--warning-color); }
        .completed-value { color: var(--success-color); }

        .progress-bar-container {
            width: 100%;
            height: 6px;
            background: var(--border-color);
            border-radius: 3px;
            margin-top: 10px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            width: 0%;
            background: var(--success-color);
            transition: width 0.3s ease;
        }

        .meta-item.item-done {
            border-color: var(--success-color);
            opacity: 0.7;
        }
        .meta-item.item-done .item-title {
            text-decoration: line-through;
            opacity: 0.5;
        }

        footer {
            margin-top: 30px;
            text-align: center;
            font-size: 12px;
            opacity: 0.6;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>Nossas Metas & Conquistas 🏢🚗</h1>
        <p>Planejamento livre e financeiro a dois</p>
    </header>

    <!-- Painel Geral -->
    <div class="dashboard">
        <div class="dash-card">
            <h4>Total Necessário</h4>
            <p id="total-geral">R$ 0,00</p>
        </div>
        <div class="dash-card">
            <h4>Total Guardado</h4>
            <p id="total-guardado">R$ 0,00</p>
        </div>
        <div class="dash-card">
            <h4>Total que Falta</h4>
            <p id="total-falta" style="color: var(--warning-color);">R$ 0,00</p>
        </div>
    </div>

    <!-- Campo para Adicionar Novo Item -->
    <div class="add-form">
        <input type="text" id="novo-item-nome" placeholder="O que vamos planejar agora? Ex: Sofá Retrátil...">
        <button id="btn-adicionar">Adicionar</button>
    </div>

    <!-- Onde os itens vão aparecer -->
    <div id="lista-container">
        <div id="lista-vazia">Nenhum plano adicionado ainda. Comece digitando acima! 🚀</div>
    </div>

    <footer>
        <p>Construindo nosso futuro juntos. 🥂</p>
    </footer>
</div>

<script>
    // Array que guardará todos os itens na memória
    let metas = [];

    // Carrega do banco local do navegador ao abrir a página
    const carregarDadosSalvos = () => {
        const dados = localStorage.getItem('minhas_metas_casal');
        if (dados) {
            metas = JSON.parse(dados);
        }
    };

    // Salva o estado atual no navegador
    const salvarDados = () => {
        localStorage.setItem('minhas_metas_casal', JSON.stringify(metas));
    };

    const formatMoeda = (valor) => {
        return valor.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    };

    // Renderiza a lista completa e atualiza o painel
    const renderizarLista = () => {
        const container = document.getElementById('lista-container');
        const vaziaDiv = document.getElementById('lista-vazia');
        
        // Limpa o container tirando os itens velhos (mantendo só a div vazia se necessário)
        container.querySelectorAll('.meta-item').forEach(el => el.remove());

        if (metas.length === 0) {
            vaziaDiv.style.display = 'block';
        } else {
            vaziaDiv.style.display = 'none';
        }

        let globalTotal = 0;
        let globalGuardado = 0;
        let globalFalta = 0;

        metas.forEach((meta, index) => {
            const total = parseFloat(meta.total) || 0;
            const guardado = parseFloat(meta.guardado) || 0;
            let falta = total - guardado;
            if (falta < 0) falta = 0;

            globalTotal += total;
            globalGuardado += guardado;
            globalFalta += falta;

            const pPct = total > 0 ? Math.min((guardado / total) * 100, 100) : 0;

            // Cria o elemento HTML do item
            const itemDiv = document.createElement('div');
            itemDiv.className = `meta-item ${meta.checked ? 'item-done' : ''}`;
            
            itemDiv.innerHTML = `
                <div class="item-main">
                    <div class="item-left">
                        <input type="checkbox" class="done-check" ${meta.checked ? 'checked' : ''}>
                        <span class="item-title">${meta.nome}</span>
                    </div>
                    <div class="item-actions">
                        <button class="action-btn btn-search" title="Pesquisar preço no Google Shopping">🔍</button>
                        <button class="action-btn btn-delete" title="Excluir item" style="color: var(--danger-color);">🗑️</button>
                    </div>
                </div>
                <div class="item-finances">
                    <div class="input-group">
                        <label>Valor Total</label>
                        <input type="number" class="val-total" value="${meta.total}" placeholder="0.00" step="0.01">
                    </div>
                    <div class="input-group">
                        <label>Já Guardado</label>
                        <input type="number" class="val-guardado" value="${meta.guardado}" placeholder="0.00" step="0.01">
                    </div>
                    <div class="input-group">
                        <label>Falta</label>
                        <div class="result-box ${falta === 0 && total > 0 ? 'completed-value' : 'missing-value'}">
                            ${falta === 0 && total > 0 ? 'Concluído!' : formatMoeda(falta)}
                        </div>
                    </div>
                </div>
                <div class="progress-bar-container">
                    <div class="progress-bar" style="width: ${pPct}%"></div>
                </div>
            `;

            // EVENTOS DO ITEM DINÂMICO
            
            // Checkbox de concluir
            itemDiv.querySelector('.done-check').addEventListener('change', (e) => {
                metas[index].checked = e.target.checked;
                salvarDados();
                renderizarLista();
            });

            // Inputs de Valores
            itemDiv.querySelector('.val-total').addEventListener('input', (e) => {
                metas[index].total = e.target.value;
                salvarDados();
                atualizarApenasTotais(); // Melhora performance ao digitar
            });

            itemDiv.querySelector('.val-guardado').addEventListener('input', (e) => {
                metas[index].guardado = e.target.value;
                salvarDados();
                atualizarApenasTotais();
            });

            // Botão Pesquisar Google Shopping
            itemDiv.querySelector('.btn-search').addEventListener('click', () => {
                const query = encodeURIComponent(meta.nome);
                window.open(`https://www.google.com/search?tbm=shop&q=${query}`, '_blank');
            });

            // Botão Excluir
            itemDiv.querySelector('.btn-delete').addEventListener('click', () => {
                metas.splice(index, 1);
                salvarDados();
                renderizarLista();
            });

            container.appendChild(itemDiv);
        });

        // Atualiza o painel superior
        document.getElementById('total-geral').textContent = formatMoeda(globalTotal);
        document.getElementById('total-guardado').textContent = formatMoeda(globalGuardado);
        document.getElementById('total-falta').textContent = formatMoeda(globalFalta);
    };

    // Função rápida para recalcular valores e atualizar barras enquanto o usuário digita
    const atualizarApenasTotais = () => {
        let globalTotal = 0;
        let globalGuardado = 0;
        let globalFalta = 0;

        document.querySelectorAll('.meta-item').forEach((item, index) => {
            const inputTotal = item.querySelector('.val-total');
            const inputGuardado = item.querySelector('.val-guardado');
            const resultBox = item.querySelector('.result-box');
            const progressBar = item.querySelector('.progress-bar');

            const total = parseFloat(inputTotal.value) || 0;
            const guardado = parseFloat(inputGuardado.value) || 0;
            let falta = total - guardado;
            if (falta < 0) falta = 0;

            globalTotal += total;
            globalGuardado += guardado;
            globalFalta += falta;

            if (falta === 0 && total > 0) {
                resultBox.textContent = "Concluído!";
                resultBox.className = "result-box completed-value";
            } else {
                resultBox.textContent = formatMoeda(falta);
                resultBox.className = "result-box missing-value";
            }

            const pPct = total > 0 ? Math.min((guardado / total) * 100, 100) : 0;
            progressBar.style.width = `${pPct}%`;
        });

        document.getElementById('total-geral').textContent = formatMoeda(globalTotal);
        document.getElementById('total-guardado').textContent = formatMoeda(globalGuardado);
        document.getElementById('total-falta').textContent = formatMoeda(globalFalta);
    };

    // Ação do Botão Adicionar do topo
    const adicionarNovoItem = () => {
        const inputNome = document.getElementById('novo-item-nome');
        const nome = inputNome.value.trim();

        if (nome === '') return;

        metas.push({
            nome: nome,
            checked: false,
            total: '',
            guardado: ''
        });

        inputNome.value = ''; // Limpa o campo
        salvarDados();
        renderizarLista();
    };

    document.getElementById('btn-adicionar').addEventListener('click', adicionarNovoItem);
    document.getElementById('novo-item-nome').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') adicionarNovoItem();
    });

    // Inicialização da página
    carregarDadosSalvos();
    renderizarLista();
</script>

</body>
</html>
